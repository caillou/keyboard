#!/bin/sh

set -e

which -s brew || (echo "Homebrew is required: http://brew.sh/" && exit 1)

brew bundle check || brew bundle

# Install busted (Lua test framework) into a project-local tree so nothing
# leaks into global package state. luarocks no-ops if already installed.
luarocks --tree=lua_modules install busted

# Install luacheck (Lua linter) into the same project-local tree.
# luacheck's source reassigns generic-for loop variables, which Lua 5.5 rejects
# (loop variables are const-by-default there), so it must run under Lua 5.4.
# lua@5.4 (keg-only, no conflict with the default `lua`) is declared in the
# Brewfile and installed by `brew bundle` above; we just build luacheck against
# it here. luarocks no-ops if luacheck is already installed.
luarocks --tree=lua_modules --lua-version=5.4 --lua-dir="$(brew --prefix lua@5.4)" install luacheck

# Prepare custom settings for Hammerspoon
mkdir -p ~/.hammerspoon

# Pre-create the install target for the `hs` CLI tool (hs.ipc.cliInstall in
# init.lua symlinks into ~/.local/bin and ~/.local/share/man/man1).
mkdir -p ~/.local/bin ~/.local/share/man/man1
if ! grep -sq "require('keyboard')" ~/.hammerspoon/init.lua; then
  echo "require('keyboard') -- Load Hammerspoon bits from https://github.com/jasonrudolph/keyboard" >> ~/.hammerspoon/init.lua
fi

ln -sfn $PWD/hammerspoon ~/.hammerspoon/keyboard

# Symlink the vendored EmmyLua.spoon so Hammerspoon loads it from ~/.hammerspoon/Spoons.
# The generator hardcodes its output to the Spoon's own resourcePath, so this
# symlink makes the generated annotations land physically inside the repo (where
# the editor reads them). Mirrors the keyboard symlink above; idempotent.
mkdir -p ~/.hammerspoon/Spoons
ln -sfn $PWD/hammerspoon/Spoons/EmmyLua.spoon ~/.hammerspoon/Spoons/EmmyLua.spoon

# Prepare custom settings for navigating between words in iTerm2
# grep -sq forward-word ~/.inputrc || cat $PWD/inputrc >> ~/.inputrc

# Disable Dock icon for Hammerspoon
defaults write org.hammerspoon.Hammerspoon MJShowDockIconKey -bool FALSE

# If Hammerspoon is already running, kill it so we can pick up the new config
# when opening Hammerspoon below
killall Hammerspoon || true

# Give LaunchServices a moment to clear the old process record — relaunching
# too fast after killall can fail with `_LSOpenURLsWithCompletionHandler() -600`.
sleep 1

# Open Apps
open /Applications/Hammerspoon.app

# Enable apps at startup (guard against duplicate login items on re-runs)
osascript -e 'tell application "System Events" to if not (exists login item "Hammerspoon") then make login item at end with properties {path:"/Applications/Hammerspoon.app", hidden:true}' > /dev/null
# osascript -e 'tell application "System Events" to if not (exists login item "Karabiner-Elements") then make login item at end with properties {path:"/Applications/Karabiner-Elements.app", hidden:true}' > /dev/null

# Give Hammerspoon a moment to boot and run cliInstall in init.lua, then verify
# the `hs` CLI is callable. ~/.local/bin must be on PATH; otherwise suggest the
# one-liner to add it (assumes fish; persistent universal variable).
sleep 2
if PATH="$HOME/.local/bin:$PATH" hs -c "1+1" >/dev/null 2>&1; then
  echo "✓ hs CLI is callable"
else
  echo "⚠ hs CLI not callable. If ~/.local/bin/hs exists, ~/.local/bin is not on your PATH."
  echo "  In fish, run: fish_add_path ~/.local/bin"
fi

echo "Done! Remember to enable Accessibility for Hammerspoon."
